FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      dynamicMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dynamicFvMesh   dynamicPointDisplacementFvMesh;

solvers
{
    box
    {
        motionSolverLibs ( floaterMotion );

        motionSolver    floaterMeshMotionSolver;

        floaterMeshMotionSolverCoeffs
        {
            patches         (box);
            innerDistance   0.075;
            outerDistance   0.4;

            separateMeshMorphing true;
            xMorphing
            {
                coordinateSystem
                {
                    origin  (0 0 0);
                    e1      (1 0 0);
                    e2      (0 1 0);
                }

                // Coordinates specified relative to body or lab
                relativeTo  lab; //default: lab

                innerBox { xMin -0.5;  xMax  0.5;}
                outerBox { xMin -2.2;  xMax  2.2;}
            }
            zMorphing
            {
                $xMorphing;

                innerBox { zMin -0.21; zMax  0.19; }
                outerBox { zMin -0.39; zMax  0.39; }
            }

            linDirs   (1 0 1);
            rotDirs   (0 1 0);
            addedMassModel  pisoAddedMass;
            MaddUpdateFreq  1;

            restraints
            {
            }
        }
    }
}


