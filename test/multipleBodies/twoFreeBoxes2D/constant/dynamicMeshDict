FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      dynamicMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dynamicFvMesh        dynamicPointDisplacementFvMesh;

solvers
{
    box
    {
        motionSolverLibs    ("libfloaterMotion.so");
        motionSolver        floaterMeshMotionSolver;

        floaterMeshMotionSolverCoeffs
        {
            patches         (floatingObject);
            innerDistance   5;
            outerDistance   70;
            separateMeshMorphing true;
            xMorphing
            {
                coordinateSystem
                {
                    origin  (0 0 0);
                    e1      (1 0 0);
                    e2      (0 1 0);
                }

                // Coordinates specified relative to body or lab
                relativeTo  lab; //default: lab

                innerBox { xMin 75;  xMax  125;}
                outerBox { xMin 5;  xMax  275;}
            }
            zMorphing
            {
                $xMorphing;

                innerBox { zMin 85; zMax  1e6; }
                outerBox { zMin 5; zMax  1e8; }
            }

            linDirs         (1 0 1);
            rotDirs         (0 1 0);

            MaddUpdateFreq  3;
            addedMassModel  pisoAddedMass;
        }
    }

    box2
    {
        motionSolverLibs    ("libfloaterMotion.so");
        motionSolver        floaterMeshMotionSolver;

        floaterMeshMotionSolverCoeffs
        {
            patches         (floatingObject2);
            innerDistance   5;
            outerDistance   70;

            separateMeshMorphing true;
            xMorphing
            {
                coordinateSystem
                {
                    origin  (0 0 0);
                    e1      (1 0 0);
                    e2      (0 1 0);
                }

                // Coordinates specified relative to body or lab
                relativeTo  lab; //default: lab

                innerBox { xMin 275;  xMax  325;}
                outerBox { xMin 125;  xMax  395;}
            }
            zMorphing
            {
                $xMorphing;

                innerBox { zMin 85; zMax  1e6; }
                outerBox { zMin 5; zMax  1e8; }
            }

            linDirs         (1 0 1);
            rotDirs         (0 1 0);

            MaddUpdateFreq  3;
            addedMassModel  pisoAddedMass;
        }
    }

}

